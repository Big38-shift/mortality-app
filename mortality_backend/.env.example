# Backend Environment Variables Template
# Copy this to .env in mortality_backend/ directory

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# JWT Secret (Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-min-32-chars

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated) - Allow these frontend URLs to access the API
# For development: http://localhost:3000 (React dev), http://localhost:5173 (Vite dev)
# For production: add your Vercel domain
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://mortality-predictor.vercel.app
